FROM node:22-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_AUTH_API_URL
ARG VITE_PATIENT_API_URL
ARG VITE_CONSULTATION_API_URL
ARG VITE_LABORATORY_API_URL
ARG VITE_IMAGING_API_URL
ARG VITE_REPOSITORY_API_URL

ENV VITE_AUTH_API_URL=$VITE_AUTH_API_URL
ENV VITE_PATIENT_API_URL=$VITE_PATIENT_API_URL
ENV VITE_CONSULTATION_API_URL=$VITE_CONSULTATION_API_URL
ENV VITE_LABORATORY_API_URL=$VITE_LABORATORY_API_URL
ENV VITE_IMAGING_API_URL=$VITE_IMAGING_API_URL
ENV VITE_REPOSITORY_API_URL=$VITE_REPOSITORY_API_URL

RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
